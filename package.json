{
  "name": "caesar-app",
  "version": "0.1.0",
  "private": true,
  "workspaces": ["apps/*", "apps/*/*", "packages/*"],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "turbo run format",
    "test": "turbo run test",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "clean": "turbo clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@types/node": "^22.10.5",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  },
  "packageManager": "bun@1.2.20",
  "engines": {
    "node": ">=22.0.0",
    "bun": ">=1.1.0"
  }
}
