{
  "name": "@caesar/crypto",
  "version": "0.0.0",
  "private": true,
  "description": "Shared cryptography package for Caesar App",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist"],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "clean": "rm -rf dist .turbo node_modules"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@caesar/typescript-config": "workspace:*",
    "typescript": "^5.7.2"
  },
  "keywords": ["cryptography", "web-crypto", "encryption", "aes-gcm", "rsa-oaep", "ecdh", "scrypt"],
  "dependencies": {
    "comlink": "^4.4.2"
  }
}
