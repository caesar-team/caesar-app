# Database
DATABASE_URL="postgresql://user:password@localhost:5432/caesar_db"
# For development with SQLite:
# DATABASE_URL="file:./dev.db"

# Better Auth Configuration
# Generate a secret with: openssl rand -base64 32
BETTER_AUTH_SECRET="your-secret-key-min-32-characters-long-here"
BETTER_AUTH_URL="http://localhost:3000"

# Passkeys Configuration
# For local development, use "localhost"
# For production, use your domain (e.g., "caesar-app.com")
PASSKEY_RP_ID="localhost"

# Application URL (Client-side)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Node Environment
NODE_ENV="development"
